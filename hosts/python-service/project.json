{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "python-service",
  "root": "hosts/python-service",
  "projectType": "application",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run tools/workspace-dev/src/placeholder-host.ts --host python"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run tools/workspace-dev/src/placeholder-host.ts --host python --mode build"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run tools/workspace-dev/src/placeholder-host.ts --host python --mode test"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run tools/workspace-dev/src/placeholder-host.ts --host python --mode lint"
      }
    }
  }
}
