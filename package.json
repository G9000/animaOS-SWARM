    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@nx/devkit": "22.6.3",
    "@nx/esbuild": "22.6.3",
    "@nx/js": "22.6.3",
    "@nx/node": "^22.6.3",
    "@nx/playwright": "22.6.3",
    "@nx/react": "^22.6.3",
    "@nx/vite": "22.6.3",
    "@nx/vitest": "22.6.2",
    "@nx/web": "^22.6.3",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "20.19.9",
