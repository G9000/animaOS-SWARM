{
  "name": "animaOS-SWARM",
  "version": "0.0.0",
  "packageManager": "bun@1.3.8",
  "license": "MIT",
  "scripts": {
    "affected:build": "bun x nx affected -t build",
    "affected:test": "bun x nx affected -t test",
    "build": "bun x nx run-many -t build",
    "build:cli-sdk": "tsc -b packages/sdk/tsconfig.lib.json packages/cli/tsconfig.lib.json",
    "daemon": "cargo run --manifest-path Cargo.toml -p anima-daemon",
    "dev": "bun x nx run workspace-dev:dev --",
    "animaos": "node packages/cli/dist/index.js",
    "graph": "bun x nx graph",
    "lint": "oxlint --config .oxlintrc.json packages/*/src apps/*/src",
    "lint:fix": "oxlint --fix --config .oxlintrc.json packages/*/src apps/*/src",
    "projects": "bun x nx show projects",
    "server": "bun x nx serve @animaOS-SWARM/server",
    "test": "bun x nx run-many -t test",
    "typecheck": "bun x nx run-many -t typecheck",
    "web": "bun x nx dev @animaOS-SWARM/web"
  },
  "private": true,
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@nx/devkit": "^22.7.1",
    "@nx/esbuild": "^22.7.1",
    "@nx/js": "^22.7.1",
    "@nx/node": "^22.7.1",
    "@nx/playwright": "^22.7.1",
    "@nx/react": "^22.7.1",
    "@nx/vite": "^22.7.1",
    "@nx/vitest": "^22.7.1",
    "@nx/web": "^22.7.1",
    "@playwright/test": "^1.59.1",
    "@swc-node/register": "1.11.1",
    "@swc/core": "^1.15.32",
    "@swc/helpers": "^0.5.21",
    "@types/node": "^20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "esbuild": "^0.28.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.1",
    "nx": "^22.7.1",
    "oxlint": "^1.62.0",
    "prettier": "^3.8.3",
    "tslib": "^2.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "mods/*",
    "tools/*"
  ]
}
