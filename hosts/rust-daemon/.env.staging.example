# Rust daemon staging profile.
# Copy values into your hosting provider's secret/env settings. Do not commit real secrets.

ANIMAOS_RS_HOST=0.0.0.0
ANIMAOS_RS_PORT=8080
ANIMAOS_RS_PERSISTENCE_MODE=postgres
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/anima_staging

# Staging defaults. Increase cautiously because each run can hold model/tool resources.
ANIMAOS_RS_REQUEST_TIMEOUT_SECS=60
ANIMAOS_RS_MAX_REQUEST_BYTES=262144
ANIMAOS_RS_MAX_CONCURRENT_RUNS=8
ANIMAOS_RS_MAX_BACKGROUND_PROCESSES=4

# V1 staging vector path: keep vectors in process and rebuild from Postgres memory snapshots on boot.
# If your host has a persistent volume, you can enable SQLite vector caching instead:
# ANIMAOS_RS_MEMORY_EMBEDDINGS_SQLITE_FILE=/var/lib/anima/memory-embeddings.sqlite
ANIMAOS_RS_MEMORY_EMBEDDINGS=local

# Optional real semantic embeddings. Use one provider profile at a time.
# ANIMAOS_RS_MEMORY_EMBEDDINGS=fastembed
# ANIMAOS_RS_MEMORY_EMBEDDING_MODEL=intfloat/multilingual-e5-small
# ANIMAOS_RS_MEMORY_EMBEDDINGS_CACHE_DIR=/var/lib/anima/fastembed-cache
# ANIMAOS_RS_MEMORY_EMBEDDINGS=ollama
# ANIMAOS_RS_MEMORY_EMBEDDING_MODEL=nomic-embed-text
# ANIMAOS_RS_MEMORY_EMBEDDINGS_BASE_URL=https://your-ollama.example.com/v1

# Model provider credentials. Set at least one provider used by your staged agents.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=...
# MOONSHOT_API_KEY=...

RUST_LOG=info,tower_http=info