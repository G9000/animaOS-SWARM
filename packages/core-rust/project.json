{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "core-rust",
  "root": "packages/core-rust",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "cargo build --manifest-path Cargo.toml --target-dir target/core-rust/build -p anima-core -p anima-memory -p anima-swarm"
      },
      "inputs": [
        "default",
        "{workspaceRoot}/Cargo.toml",
        "{workspaceRoot}/Cargo.lock",
        "{workspaceRoot}/packages/core-rust/crates/**/*"
      ]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "cargo test --manifest-path Cargo.toml --target-dir target/core-rust/test -p anima-core -p anima-memory -p anima-swarm"
      },
      "inputs": [
        "default",
        "{workspaceRoot}/Cargo.toml",
        "{workspaceRoot}/Cargo.lock",
        "{workspaceRoot}/packages/core-rust/crates/**/*"
      ]
    },
    "memory-eval": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "cargo test --manifest-path Cargo.toml --target-dir target/core-rust/memory-eval -p anima-memory baseline_memory_eval_cases_pass"
      },
      "inputs": [
        "default",
        "{workspaceRoot}/Cargo.toml",
        "{workspaceRoot}/Cargo.lock",
        "{workspaceRoot}/packages/core-rust/crates/anima-memory/**/*"
      ]
    },
    "memory-locomo": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "cargo test --manifest-path Cargo.toml --target-dir target/core-rust/memory-locomo -p anima-memory locomo_smoke_eval_cases_pass --features locomo-eval"
      },
      "inputs": [
        "default",
        "{workspaceRoot}/Cargo.toml",
        "{workspaceRoot}/Cargo.lock",
        "{workspaceRoot}/packages/core-rust/crates/anima-memory/**/*"
      ]
    },
    "memory-locomo-fetch": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "cwd": ".",
        "command": "bun tools/memory-eval/download-locomo.mjs"
      },
      "inputs": [
        "default",
        "{workspaceRoot}/tools/memory-eval/download-locomo.mjs"
      ]
    },
    "memory-locomo-dataset": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "cwd": ".",
        "command": "bun tools/memory-eval/run-locomo-dataset.mjs"
      },
      "inputs": [
        "default",
        "{workspaceRoot}/Cargo.toml",
        "{workspaceRoot}/Cargo.lock",
        "{workspaceRoot}/packages/core-rust/crates/anima-memory/**/*",
        "{workspaceRoot}/tools/memory-eval/download-locomo.mjs",
        "{workspaceRoot}/tools/memory-eval/run-locomo-dataset.mjs"
      ]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "cargo fmt --manifest-path Cargo.toml --package anima-core --package anima-memory --package anima-swarm --check"
      },
      "inputs": [
        "default",
        "{workspaceRoot}/Cargo.toml",
        "{workspaceRoot}/Cargo.lock",
        "{workspaceRoot}/packages/core-rust/crates/**/*"
      ]
    }
  }
}
