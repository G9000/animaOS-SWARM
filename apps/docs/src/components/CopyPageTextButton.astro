---
const { variant = 'toolbar', label = 'Copy Page As Text', placement = 'default' } = Astro.props;
const isIcon = variant === 'icon';
---

<div
  class:list={['copy-docs-toolbar', isIcon && 'copy-docs-toolbar-inline']}
  data-copy-docs-toolbar
  data-copy-docs-placement={placement}
>
  <button
    type="button"
    class:list={['copy-docs-button', isIcon && 'copy-docs-button-icon']}
    data-copy-docs-button
    aria-label={label}
    title={label}
  >
    {
      isIcon ? (
        <>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
              d="M15 1H6a2 2 0 0 0-2 2v12h2V3h9V1Zm3 4H10a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2Zm0 16H10V7h8v14Z"
              fill="currentColor"
            />
          </svg>
          <span class="copy-docs-sr-only">{label}</span>
        </>
      ) : (
        label
      )
    }
  </button>
  <span class:list={['copy-docs-status', isIcon && 'copy-docs-status-inline']} aria-live="polite" data-copy-docs-status></span>
</div>

<script is:inline>
  (() => {
    if (typeof window === 'undefined') {
      return;
    }

    const selectorsToRemove = [
      '[data-slot="doc-title-actions"]',
      '.sl-anchor-link',
      '.copy',
      '.sr-only',
      'script',
      'style',
      'svg',
      'button',
      '[aria-hidden="true"]',
      '[hidden]',
    ].join(',');

    const normalizeText = (value) =>
      value
        .replace(/\u00a0/g, ' ')
        .replace(/\n{3,}/g, '\n\n')
        .replace(/[ \t]+\n/g, '\n')
        .trim();

    const fallbackCopy = (text) => {
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      textarea.style.pointerEvents = 'none';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      textarea.remove();
    };

    const extractPageText = (button) => {
      const pageRoot = button.closest('main[data-pagefind-body]') ?? document.querySelector('main[data-pagefind-body]');

      if (!(pageRoot instanceof HTMLElement)) {
        return '';
      }

      const clone = pageRoot.cloneNode(true);

      if (!(clone instanceof HTMLElement)) {
        return '';
      }

      clone.querySelectorAll(selectorsToRemove).forEach((node) => node.remove());

      const sandbox = document.createElement('div');
      sandbox.style.position = 'fixed';
      sandbox.style.inset = '0';
      sandbox.style.opacity = '0';
      sandbox.style.pointerEvents = 'none';
      sandbox.style.zIndex = '-1';
      document.body.appendChild(sandbox);
      sandbox.appendChild(clone);

      const text = normalizeText(sandbox.innerText || clone.innerText || '');
      sandbox.remove();
      return text;
    };

    const updateStatus = (toolbar, message, isError = false) => {
      const status = toolbar.querySelector('[data-copy-docs-status]');
      if (!(status instanceof HTMLElement)) {
        return;
      }

      status.textContent = message;
      status.dataset.state = isError ? 'error' : 'success';
      window.clearTimeout(Number(status.dataset.timeoutId || '0'));
      const timeoutId = window.setTimeout(() => {
        status.textContent = '';
        delete status.dataset.state;
        delete status.dataset.timeoutId;
      }, 2200);
      status.dataset.timeoutId = String(timeoutId);
    };

    const bindToolbar = (toolbar) => {
      if (!(toolbar instanceof HTMLElement) || toolbar.dataset.copyDocsBound === 'true') {
        return;
      }

      if (toolbar.dataset.copyDocsPlacement === 'title-actions') {
        const actions = document.querySelector('[data-slot="doc-title-actions"]');
        if (actions instanceof HTMLElement && toolbar.parentElement !== actions) {
          actions.insertBefore(toolbar, actions.querySelector('a, button'));
        }
      }

      const button = toolbar.querySelector('[data-copy-docs-button]');
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      toolbar.dataset.copyDocsBound = 'true';

      button.addEventListener('click', async () => {
        const text = extractPageText(button);
        if (!text) {
          updateStatus(toolbar, 'Nothing to copy', true);
          return;
        }

        try {
          if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
          } else {
            fallbackCopy(text);
          }
          updateStatus(toolbar, 'Copied plain text');
        } catch {
          try {
            fallbackCopy(text);
            updateStatus(toolbar, 'Copied plain text');
          } catch {
            updateStatus(toolbar, 'Copy failed', true);
          }
        }
      });
    };

    document.querySelectorAll('[data-copy-docs-toolbar]').forEach(bindToolbar);
  })();
</script>

<style>
  .copy-docs-toolbar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin: 0 0 1.5rem;
  }

  .copy-docs-toolbar-inline {
    position: relative;
    gap: 0;
    flex-wrap: nowrap;
    margin: 0;
  }

  .copy-docs-button {
    appearance: none;
    border: 1px solid var(--border);
    background: var(--gray-6);
    color: var(--foreground);
    border-radius: calc(var(--radius) + 2px);
    padding: 0.55rem 0.9rem;
    font: inherit;
    font-size: 0.95rem;
    line-height: 1;
    cursor: pointer;
    transition: background-color 120ms ease, border-color 120ms ease, transform 120ms ease;
  }

  .copy-docs-button svg {
    width: 1rem;
    height: 1rem;
    display: block;
  }

  .copy-docs-button-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border-radius: 999px;
  }

  .copy-docs-button:hover {
    background: var(--gray-5);
    border-color: color-mix(in srgb, var(--border) 55%, var(--foreground) 45%);
  }

  .copy-docs-button:focus-visible {
    outline: 2px solid var(--accent-regular);
    outline-offset: 2px;
  }

  .copy-docs-button:active {
    transform: translateY(1px);
  }

  .copy-docs-status {
    min-height: 1lh;
    color: var(--muted-foreground);
    font-size: 0.92rem;
  }

  .copy-docs-status-inline {
    position: absolute;
    top: calc(100% + 0.45rem);
    right: 0;
    min-height: 0;
    padding: 0.3rem 0.5rem;
    border-radius: 0.45rem;
    border: 1px solid var(--border);
    background: var(--gray-6);
    box-shadow: 0 8px 24px rgb(15 23 42 / 0.14);
    white-space: nowrap;
    opacity: 0;
    transform: translateY(-0.15rem);
    transition: opacity 120ms ease, transform 120ms ease;
    pointer-events: none;
  }

  .copy-docs-status-inline[data-state] {
    opacity: 1;
    transform: translateY(0);
  }

  .copy-docs-status[data-state='error'] {
    color: var(--sl-color-red-high);
  }

  .copy-docs-status[data-state='success'] {
    color: var(--sl-color-green-high);
  }

  .copy-docs-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  </style>